generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  createdAt DateTime @default(now())

  feedbacks Feedback[]
}
model Feedback {
  id        String   @id @default(cuid())
  content   String
  channel   String?
  sentiment String?
  theme     String?
  createdAt DateTime @default(now())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
}

enum Role {
  ADMIN
  ANALYST
  VIEWER
}
